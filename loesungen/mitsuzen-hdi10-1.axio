// XA
NOTE READ VALUE FROM CNS
LINK 800
NOOP
NOOP
NOOP

MARK INFINIT_LOOP
  COPY #NERV X
  TEST X < -120
    FJMP CHECK_GT_50
  COPY -120 X
  MARK CHECK_GT_50
  TEST X > 50
    FJMP LT_50
  COPY 50 X 
  MARK LT_50
  COPY X M

  JUMP INFINIT_LOOP

// XB
NOTE RELAY VALUE TO ARM
LINK 800
LINK 1
LINK 1
LINK 1
LINK 1

MARK INFINIT_LOOP
  COPY M #NERV

  JUMP INFINIT_LOOP